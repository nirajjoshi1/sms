# API Configuration
# Local: use your local backend.
# Production frontend on Vercel: use your deployed backend URL ending in /api/v1.
VITE_API_URL=http://localhost:5000/api/v1

# Cloudinary Configuration (for direct uploads from client)
# Get from: https://cloudinary.com/console
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name

# Optional: Analytics (Production)
# VITE_GA_TRACKING_ID=your_google_analytics_id

# Optional: Sentry (Production Error Tracking)
# VITE_SENTRY_DSN=your_sentry_dsn
