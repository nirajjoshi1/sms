# API Configuration
# Local development only. Production builds always use relative URLs (/api/v1).
# Do not add VITE_API_URL in Vercel.
VITE_API_URL=http://localhost:5000/api/v1

# Cloudinary Configuration (for direct uploads from client)
# Get from: https://cloudinary.com/console
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name

# Optional: Analytics (Production)
# VITE_GA_TRACKING_ID=your_google_analytics_id

# Optional: Sentry (Production Error Tracking)
# VITE_SENTRY_DSN=your_sentry_dsn
