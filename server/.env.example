# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Neon PostgreSQL)
# Get your connection string from: https://console.neon.tech
DATABASE_URL=postgresql://username:password@ep-xxxxx.region.neon.tech/dbname?sslmode=require

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRY=7d

# Cloudinary Configuration (Image Storage)
# Get credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Configuration (Nodemailer)
# For Gmail: Use App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Frontend URL (for CORS)
# Production: Add your Vercel domain, comma-separated for multiple origins
# Example: https://yourapp.vercel.app,https://www.yourdomain.com
CLIENT_URL=http://localhost:5173

# Optional: Sentry for Error Tracking (Production)
# SENTRY_DSN=your_sentry_dsn

# Optional: Redis for Session Storage (Production)
# REDIS_URL=your_redis_connection_string
